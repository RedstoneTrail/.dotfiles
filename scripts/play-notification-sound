#!/usr/bin/env zsh

# MEDIA_STATUS=$(playerctl status 2>/dev/null || echo "not playing")

# if [ $MEDIA_STATUS = "Playing" ]
# then
# 	# playerctl pause
# 	playerctl volume 0.5-
# fi

play_cmd () {
	paplay --volume=49152 ~/.dotfiles/dunst/notification-${1}.*
}

sleep_cmd () {
	sleep 0.25
}

case "$(echo $@ | rev | cut -f1 -d\  | rev)" in
	CRITICAL)
		play_cmd critical
		;;
	NORMAL)
		play_cmd normal
		;;
	LOW)
		play_cmd low
		;;
esac

