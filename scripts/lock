#!/usr/bin/env sh

if [ -e /tmp/inhibitor ] && [ "$1" == "lid" ]
then
	lock_cmd=
else
	lock_cmd="hyprlock"
fi

if pactl get-sink-mute @DEFAULT_SINK@ | grep no; then
	playerctl -a pause
	pactl set-sink-mute @DEFAULT_SINK@ true

	if [ "$1" == "lid" ];
	then
		echo locked at $(date) > /tmp/open

		systemctl sleep

		$lock_cmd
	else
		$lock_cmd
	fi

	echo unlocked at $(date) >> /tmp/open

	pactl set-sink-mute @DEFAULT_SINK@ false
else
	playerctl -a pause
	$lock_cmd
fi
